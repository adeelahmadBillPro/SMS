# ShopOS environment variables — source of truth for all .env files
# Copy to .env (dev) or /etc/shopos/.env (prod) and fill in real values.
# See SETUP.md for production guidance.

# ============================================================
# Database — three connection strings, three roles
# ============================================================
#
# DATABASE_URL         — superuser. Used by `prisma migrate`, `db:rls:apply`,
#                        `db:seed`. NOT used by app runtime. MUST NOT be used
#                        by the RLS test (superuser bypasses RLS).
# DATABASE_APP_URL     — role shopos_app. No BYPASSRLS. App runtime + RLS test.
# DATABASE_ADMIN_URL   — role shopos_admin. BYPASSRLS. /admin routes only.
#
# The shopos_app and shopos_admin roles are created by `pnpm db:rls:apply`
# using the SHOPOS_*_PASSWORD env vars below. Keep those passwords in sync
# with the password embedded in the *_URL strings.

# --- Dev (local Postgres 17 on Windows) ---
# URL-encode @ in the password as %40
DATABASE_URL=postgresql://postgres:AdeelAhmad%4012345@localhost:5432/shopos_dev?schema=public
DATABASE_APP_URL=postgresql://shopos_app:shopos_app_dev_pw@localhost:5432/shopos_dev?schema=public
DATABASE_ADMIN_URL=postgresql://shopos_admin:shopos_admin_dev_pw@localhost:5432/shopos_dev?schema=public

SHOPOS_APP_PASSWORD=shopos_app_dev_pw
SHOPOS_ADMIN_PASSWORD=shopos_admin_dev_pw

# --- Redis (dev: Docker Desktop, WSL, or native on Windows) ---
REDIS_URL=redis://localhost:6379

# ============================================================
# App
# ============================================================
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Auth
# ============================================================
# Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=change-me-in-production
SESSION_COOKIE_DOMAIN=localhost

# ============================================================
# Encryption key for per-shop FBR credentials (32 bytes, base64)
# Generate: openssl rand -base64 32
# ============================================================
FBR_ENCRYPTION_KEY=change-me-in-production

# ============================================================
# Super admin bootstrap (seeded on first `pnpm db:seed`)
# ============================================================
SUPER_ADMIN_EMAIL=adeel.ahmad8000@gmail.com

# ============================================================
# Email transport
# dev: console (writes reset links to server log)
# prod: resend | smtp
# ============================================================
EMAIL_TRANSPORT=console
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=ShopOS <no-reply@shopos.example.com>

# ============================================================
# Observability (optional — no-op if empty)
# ============================================================
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================
# Backups (prod only)
# none | r2 | b2
# ============================================================
BACKUP_REMOTE=none
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=shopos-backups
