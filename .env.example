# ShopOS environment variables — source of truth for all .env files
# Copy to .env (dev) or /etc/shopos/.env (prod) and fill in real values.
# See SETUP.md for production guidance.

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (dev: local Postgres 17 on Windows) ---
# Template — URL-encode @ as %40 in the password portion
DATABASE_URL=postgresql://postgres:AdeelAhmad%4012345@localhost:5432/shopos_dev?schema=public

# Prod uses the dedicated shopos_app role created by migrations:
# DATABASE_URL=postgresql://shopos_app:<pw>@postgres:5432/shopos_prod?schema=public
# DATABASE_ADMIN_URL=postgresql://shopos_admin:<pw>@postgres:5432/shopos_prod?schema=public

# --- Redis (dev: Docker Desktop or WSL) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=change-me-in-production
SESSION_COOKIE_DOMAIN=localhost

# --- Encryption key for per-shop FBR creds (32 bytes, base64) ---
# Generate: openssl rand -base64 32
FBR_ENCRYPTION_KEY=change-me-in-production

# --- Super admin bootstrap (seeded on first db:seed) ---
SUPER_ADMIN_EMAIL=adeel.ahmad8000@gmail.com

# --- Email transport ---
# dev: console (writes reset links to server log)
# prod: resend | smtp
EMAIL_TRANSPORT=console
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=ShopOS <no-reply@shopos.example.com>

# --- Observability (optional — no-op if empty) ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Backups (prod only) ---
# none | r2 | b2
BACKUP_REMOTE=none
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=shopos-backups
